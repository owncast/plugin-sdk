[
  {
    "name": "counts first message from a user",
    "events": [
      {
        "event": "chat.message.received",
        "payload": { "id": "1", "user": "alice", "body": "hi", "timestamp": "2024-01-01T00:00:00Z" }
      }
    ],
    "expect": {
      "kv": { "count:alice": "1" }
    }
  },
  {
    "name": "increments existing count",
    "given": {
      "kv": { "count:alice": "5" }
    },
    "events": [
      {
        "event": "chat.message.received",
        "payload": { "id": "1", "user": "alice", "body": "hi", "timestamp": "2024-01-01T00:00:00Z" }
      }
    ],
    "expect": {
      "kv": { "count:alice": "6" }
    }
  },
  {
    "name": "counts per-user independently",
    "events": [
      {
        "event": "chat.message.received",
        "payload": { "user": "alice", "body": "first", "timestamp": "2024-01-01T00:00:00Z" }
      },
      {
        "event": "chat.message.received",
        "payload": { "user": "alice", "body": "second", "timestamp": "2024-01-01T00:00:01Z" }
      },
      {
        "event": "chat.message.received",
        "payload": { "user": "bob", "body": "first", "timestamp": "2024-01-01T00:00:02Z" }
      }
    ],
    "expect": {
      "kv": { "count:alice": "2", "count:bob": "1" }
    }
  }
]
